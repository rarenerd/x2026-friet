.venv/
__pycache__/
*.pyc
*.wav
# Release-quality .prg deliverables in out/ are tracked; everything else is build cruft.
*.prg
!out/*.prg
*.o65
/tmp/
.claude/
tmp_midi/
# Generated composition YAML — rebuilt by compose.py / lab.py every build
docs/composition.yaml
docs/lab_composition.yaml
# Large binary — regeneratable from make player + recording script
out/friet.mp4
# Auto-generated by the ADHD skill loader
skills-lock.json
# Generated binary blobs imported by KickAssembler — rebuilt by build_player.py
src/player/sid_body.bin
src/player/lyric_table.bin
src/player/banner_top.bin
src/player/banner_bottom.bin

# koala preview intermediates
out/*.ppm
out/friet_koala_preview.png

# Exploratory build artifacts (intermediate gens, A/B comparisons, MIDI renders)
out/gens/
out/bpm_ab/
out/midi_renders/
out/friet_lead_only.*
